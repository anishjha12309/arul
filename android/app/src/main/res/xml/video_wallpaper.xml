<?xml version="1.0" encoding="utf-8"?>
<!--
    Wallpaper service descriptor required by Android for all live wallpapers.

    Referenced from the <service> meta-data in AndroidManifest.xml
    (android.service.wallpaper). The system reads this to register
    ArulVideoWallpaperService as a selectable live wallpaper.

    We intentionally omit android:description / android:thumbnail — the
    system falls back to the app label/icon, and the user only ever reaches
    this service via our own apply flow (the live-wallpaper chooser opened
    with EXTRA_LIVE_WALLPAPER_COMPONENT pointing straight at it).
-->
<wallpaper xmlns:android="http://schemas.android.com/apk/res/android" />
