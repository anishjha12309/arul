{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts"],
  "//exclude-e2e": "Manual Neon integration tests use Node built-ins (fs/path/process) absent from @cloudflare/workers-types. vitest transpiles + runs them via esbuild; tsc must skip them so `tsc --noEmit` stays clean.",
  "exclude": ["node_modules", "dist", "test/**/*.e2e.test.ts"]
}
